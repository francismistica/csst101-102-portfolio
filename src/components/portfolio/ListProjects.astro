---
import Heading from "../ui/Heading.astro";
import { Icon } from "astro-icon/components";
import Project from "./Project.astro";

const projects = (
  await Astro.glob("../../pages/portfolio/projects/*.md")
).filter(
  (project) =>
    !project.frontmatter.draft && !project.file.includes("placeholder"),
);
---

<section
  class="bg-linear-to-t dark:from-[#0e0e10] from-white from-50% to-transparent to-100% scroll-m-16 relative pt-8 pb-32 max-2xl:px-8 max-md:pt-4"
  id="projects"
>
  <div class="mx-auto max-w-7xl py-8">
    <div class="flex gap-4 items-center justify-center mb-12">
      <Icon class="text-3xl dark:text-white text-blacktext" name="code" />
      <Heading text="Featured" textGradient="Projects" level={2} />
    </div>

    <div
      class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 w-full h-full"
    >
      {
        projects.length > 0 ? (
          projects.map((project) => (
            <div
              class={
                project.frontmatter.size === "md"
                  ? "sm:col-span-2 lg:col-span-2 lg:row-span-2"
                  : ""
              }
            >
              <Project
                title={project.frontmatter.title}
                url={project.url}
                image={project.frontmatter.image}
                languages={project.frontmatter.languages}
                description={project.frontmatter.description}
                size={project.frontmatter.size}
              />
            </div>
          ))
        ) : (
          /* Coming Soon Message - Only shown if no projects exist */
          <div class="md:col-span-3 flex flex-col items-center justify-center py-16 mx-auto max-w-7xl">
            <div class="text-center p-8 max-w-lg border border-dashed border-gray-300 dark:border-gray-700 rounded-lg">
              <Icon
                name="rocket"
                class="text-5xl mb-4 mx-auto text-mint-400 dark:text-mint-300"
              />
              <h3 class="text-xl font-bold mb-2 dark:text-white text-blacktext">
                Coming Soon!
              </h3>
              <p class="text-gray-600 dark:text-gray-300">
                I'm currently working on projects that will be showcased here.
                Check back later to see my portfolio grow!
              </p>
            </div>
          </div>
        )
      }
    </div>
  </div>
</section>
