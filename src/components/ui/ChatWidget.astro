---
const startDate = new Date('2026-03-22T00:00:00');
const endDate = new Date('2026-04-17T23:59:59');
const now = new Date();

// Check if current date is within the "Try Me" visibility window
const showTryMeBadge = now >= startDate && now <= endDate;
---

<!-- Floating Trigger Button -->
<div class="fixed bottom-6 right-6 z-[90] flex flex-col items-end gap-3 animate-fade-up">
  {showTryMeBadge && (
    <!-- "Try Me" Badge -->
    <div class="relative bg-mint-500 dark:bg-mint-400 text-white dark:text-[#0E0E11] text-xs font-bold px-3 py-1.5 rounded-full shadow-lg animate-bounce">
      Try Me
      <div class="absolute -bottom-1 right-5 w-2.5 h-2.5 bg-mint-500 dark:bg-mint-400 rotate-45"></div>
    </div>
  )}

  <!-- Chat Button -->
  <button
    id="chat-widget-trigger"
    class="w-20 h-20 bg-[#0E0E11] dark:bg-mint-50 text-white dark:text-[#0E0E11] rounded-full shadow-2xl flex items-center justify-center transition-all duration-300 hover:scale-110 focus:outline-none focus:ring-4 focus:ring-mint-300/50 border-2 border-mint-500 dark:border-mint-400 overflow-hidden group p-2 cursor-pointer"
    aria-label="Open Chat"
  >
    <img
      src="/kaiko-bot-icon.png"
      alt="FM Chat Logo"
      class="w-full h-full object-contain dark:invert transition-transform group-hover:scale-105"
    />
  </button>
</div>

<!-- Chat Sheet Overlay -->
<div id="chat-overlay" class="fixed inset-0 bg-black/20 dark:bg-black/60 z-[95] hidden opacity-0 transition-opacity duration-300 backdrop-blur-sm"></div>

<!-- Chat Sheet -->
<div id="chat-sheet" class="fixed top-0 right-0 h-full w-full sm:w-[450px] bg-white dark:bg-[#0E0E11] z-[100] transform translate-x-full transition-transform duration-400 ease-[cubic-bezier(0.32,0.72,0,1)] shadow-2xl sm:border-l border-mint-500/20 flex flex-col">

  <!-- Header -->
  <div class="flex items-center justify-between p-4 border-b border-gray-100 dark:border-white/10">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-full bg-gradient-to-tr from-mint-300 to-mint-600 p-[2px]">
        <img src="/logo.png" class="w-full h-full rounded-full object-cover bg-white dark:bg-[#0E0E11] p-1" alt="Assistant Avatar" />
      </div>
      <span class="font-bold text-lg text-blacktext dark:text-white font-montserrat">Assistant</span>
    </div>
    <div class="flex items-center gap-1 text-gray-400">
      <button id="close-chat" class="p-2 transition-colors rounded-full hover:bg-gray-100 dark:hover:bg-white/10 hover:text-blacktext dark:hover:text-white">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Messages Area -->
  <div class="flex-1 overflow-y-auto p-5 space-y-6 flex flex-col font-montserrat relative scroll-smooth">

    <!-- Bot Message -->
    <div class="flex flex-col gap-1 max-w-[85%] animate-fade-up">
      <div class="bg-gray-50 dark:bg-white/5 text-blacktext dark:text-gray-200 p-4 rounded-2xl rounded-tl-sm text-[15px] leading-relaxed border border-gray-100 dark:border-white/10 shadow-sm">
        <p class="mb-4">Hey there!</p>
        <p class="mb-4">Need answers or help with your to-do list? I've got you covered!</p>
        <p>Just type what you need, and let's dive into making things happen.</p>
      </div>
    </div>

    <!-- User Message -->
    <div class="flex gap-2 max-w-[90%] self-end group relative flex-row-reverse animate-fade-up">
      <div class="bg-mint-50 dark:bg-mint-900/30 text-blacktext dark:text-gray-200 p-4 rounded-2xl rounded-tr-sm text-[15px] leading-relaxed border border-mint-100 dark:border-mint-800/50 shadow-sm">
        Create me a CSV of the top 20 SaaS companies by revenue that have raised capital in the last 12 months.
      </div>
      <!-- Hover Actions -->
      <div class="absolute -bottom-5 right-4 bg-zinc-800 text-gray-300 rounded-lg shadow-md px-2 py-1.5 flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity duration-200 z-10 border border-zinc-700">
        <button class="hover:text-white" title="Improve"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" /></svg></button>
        <button class="hover:text-white" title="Edit"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" /></svg></button>
        <button class="hover:text-white" title="Retry"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg></button>
        <button class="hover:text-white" title="Copy"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg></button>
      </div>
    </div>

    <!-- Bot Message - File -->
    <div class="flex flex-col gap-2 max-w-[85%] mt-6 animate-fade-up">
      <div class="bg-gray-50 dark:bg-white/5 text-blacktext dark:text-gray-200 p-4 rounded-2xl rounded-tl-sm text-[15px] border border-gray-100 dark:border-white/10 shadow-sm">
        Easy! Here you go.
      </div>
      <!-- Attachment -->
      <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-3 flex items-center justify-between text-white shadow-md w-full hover:bg-zinc-800 transition-colors cursor-pointer group">
        <div class="flex items-center gap-3">
          <div class="bg-[#1e7b54] text-white text-[10px] tracking-wider font-bold rounded p-2 flex items-center justify-center">CSV</div>
          <span class="text-sm font-medium truncate group-hover:underline">Top_20_SaaS_Companies.csv</span>
        </div>
        <button class="text-gray-400 hover:text-white transition-colors">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
        </button>
      </div>
    </div>

    <!-- User Message -->
    <div class="flex gap-2 max-w-[90%] self-end flex-row-reverse mt-4 animate-fade-up">
      <div class="bg-mint-50 dark:bg-mint-900/30 text-blacktext dark:text-gray-200 p-4 rounded-2xl rounded-tr-sm text-[15px] leading-relaxed border border-mint-100 dark:border-mint-800/50 shadow-sm">
        Actually, filter by U.S. companies only and include details of fundraising. Export into a new Google Sheet for me.
      </div>
    </div>

    <!-- Typing Indicator -->
    <div class="flex gap-2 max-w-[85%] mt-2 animate-fade-up">
      <div class="bg-gray-50 dark:bg-white/5 p-4 rounded-2xl rounded-tl-sm flex gap-1.5 items-center border border-gray-100 dark:border-white/10 shadow-sm h-12">
        <div class="w-1.5 h-1.5 bg-mint-500 rounded-full animate-bounce" style="animation-delay: 0ms"></div>
        <div class="w-1.5 h-1.5 bg-mint-500 rounded-full animate-bounce" style="animation-delay: 150ms"></div>
        <div class="w-1.5 h-1.5 bg-mint-500 rounded-full animate-bounce" style="animation-delay: 300ms"></div>
      </div>
    </div>

  </div>

  <!-- Input Area -->
  <div class="p-4 border-t border-gray-100 dark:border-white/10 bg-white dark:bg-[#0E0E11]">
    <div class="relative flex items-center">
      <div class="absolute left-3 flex items-center justify-center p-1 rounded-full text-gray-400 hover:text-mint-500 cursor-pointer transition-colors">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </div>

      <input
        type="text"
        placeholder="Type here..."
        class="w-full bg-transparent border-2 border-gray-200 dark:border-zinc-800 rounded-full py-3.5 pl-12 pr-12 text-[15px] font-montserrat focus:outline-none focus:border-mint-400 dark:focus:border-mint-500 focus:ring-0 text-blacktext dark:text-white transition-all placeholder:text-gray-400"
      >

      <button class="absolute right-3 p-1 text-gray-400 hover:text-mint-500 dark:hover:text-mint-400 transition-colors flex items-center justify-center">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" />
        </svg>
      </button>
    </div>
  </div>

</div>

<script>
  const chatWidgetBtn = document.getElementById('chat-widget-trigger');
  const chatSheet = document.getElementById('chat-sheet');
  const chatOverlay = document.getElementById('chat-overlay');
  const closeChatBtn = document.getElementById('close-chat');

  function openChat() {
    if(!chatOverlay || !chatSheet) return;
    chatOverlay.classList.remove('hidden');
    // slight delay for transition effect
    setTimeout(() => {
      chatOverlay.classList.remove('opacity-0');
      chatSheet.classList.remove('translate-x-full');
    }, 10);

    // Optional click animation
    if(chatWidgetBtn) {
        chatWidgetBtn.style.transform = 'scale(0.95)';
        setTimeout(() => chatWidgetBtn.style.transform = '', 150);
    }
  }

  function closeChat() {
    if(!chatOverlay || !chatSheet) return;
    chatSheet.classList.add('translate-x-full');
    chatOverlay.classList.add('opacity-0');
    setTimeout(() => {
      chatOverlay.classList.add('hidden');
    }, 400); // match transition duration
  }

  if (chatWidgetBtn) {
    chatWidgetBtn.addEventListener('click', openChat);
  }

  if (closeChatBtn) {
    closeChatBtn.addEventListener('click', closeChat);
  }

  if (chatOverlay) {
    chatOverlay.addEventListener('click', closeChat);
  }
</script>
